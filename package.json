{
  "name": "ledger",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "export JAVA_HOME=$(/usr/libexec/java_home -v 21) && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "export JAVA_HOME=$(/usr/libexec/java_home -v 21) && expo prebuild",
    "setup": "npm install && export JAVA_HOME=$(/usr/libexec/java_home -v 21) && expo prebuild"
  },
  "dependencies": {
    "expo": "^55.0.23",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.18",
    "expo-clipboard": "~55.0.13",
    "expo-crypto": "~55.0.14",
    "expo-file-system": "~55.0.19",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-notifications": "~55.0.22",
    "expo-speech": "~55.0.13",
    "expo-speech-recognition": "^3.1.3",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.17",
    "lucide-react-native": "^1.14.0",
    "moti": "^0.30.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-gesture-handler": "2.31.2",
    "react-native-litert-lm": "^0.3.7",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "4.2.1",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av",
          "react-native-fast-tflite"
        ]
      }
    }
  }
}
